{
  "_comment": "Bridge config. Each target defines: search 'queries' (buy-side), MPB 'mpb_id' (slug/URL) and optional 'mpb_floor' (EUR manual override/fallback), 'ebay_query'/'f64_query' for benchmarks, and an optional 'match' block. match.include = terms that MUST all be present in the title (use '|' for alternatives); match.exclude = extra terms that reject the listing. Global accessory excludes (grip, battery, charger, ...) are always applied. All benchmark prices are treated as EUR.",
  "targets": [
    {
      "label": "Sony A7 III (body)",
      "queries": [
        "Sony A7 III",
        "Sony A7III",
        "Sony Alpha 7 III"
      ],
      "mpb_id": "sony-a7-iii",
      "mpb_floor": 720,
      "ebay_query": "Sony A7 III body",
      "f64_query": "Sony A7 III",
      "match": {
        "include": [
          "sony",
          "a7 iii|a7iii|alpha 7 iii|ilce 7m3|ilce7m3"
        ],
        "exclude": [
          "a7 ii|a7ii|a7 iv|a7iv|a7r|a7s"
        ]
      }
    },
    {
      "label": "Canon EOS R6 (body)",
