      "mpb_id": "canon-eos-r6",
      "mpb_floor": 950,
      "ebay_query": "Canon EOS R6 body",
      "f64_query": "Canon EOS R6",
      "match": {
        "include": [
          "canon",
          "eos r6|r6"
        ],
        "exclude": [
          "r6 mark ii|r6 ii|r6ii|r5|r7|r8|r10|1300d|2000d|250d|90d|6d|5d"
