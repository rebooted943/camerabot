# Copy to .env for local runs. In CI these come from GitHub Secrets.

# --- Telegram (required for notifications) ---
TELEGRAM_TOKEN=123456789:AAExampleBotTokenFromBotFather
TELEGRAM_CHAT_ID=-1001234567890

# --- eBay Browse API (optional). If unset, eBay benchmark falls back to scraping. ---
EBAY_APP_TOKEN=

# --- Facebook Marketplace (optional). Export cookies from a logged-in browser session. ---
# FACEBOOK_COOKIES_PATH=./facebook_cookies.json

# --- Vinted (optional). Default scans all 24 EU storefronts (west + east). ---
# VINTED_REGIONS=west,east
# VINTED_MARKETS=it,ro,fr,de,pl

# --- Runtime tuning (optional, sane defaults applied) ---
# Run browsers headless (true in CI, set false locally to debug)
HEADLESS=true
# Margin used by the arbitrage trigger: buy_price <= mpb_price * MPB_MARGIN
MPB_MARGIN=0.90
# Min/max random delay (seconds) inserted between scraping requests
MIN_DELAY=2.0
MAX_DELAY=6.0
# Hard cap of ads processed per provider per target (politeness / cost control)
MAX_ITEMS_PER_PROVIDER=40
# Set to 1 to send a Telegram test ping and exit
DRY_RUN=0
